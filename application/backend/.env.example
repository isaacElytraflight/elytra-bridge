# Backend process defaults.
# Project target settings live in projects/<project-id>/real/.env and projects/<project-id>/sim/.env.
# Container secrets (e.g. GEMINI_API_KEY for habitat3-exploration) belong in the project's sim/.env;
# you may also set GEMINI_API_KEY here as a backend-wide fallback for compose interpolation.
PORT=8787
PROJECTS_DIR=../../projects
DEFAULT_PROJECT_ID=drone-2026
RECONNECT_BACKOFF_MS=3000
# GEMINI_API_KEY=
