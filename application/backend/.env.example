PORT=8787
PROJECTS_DIR=../../projects
DEFAULT_PROJECT_ID=drone-2026

# Physical drone overrides. Empty values fall back to projects/drone-2026/project.yaml.
DRONE_HOST=100.105.25.30
DRONE_PORT=22
DRONE_USER=pi
DRONE_PRIVATE_KEY_PATH=C:/Users/isaac/.ssh/id_ed25519
# DRONE_PRIVATE_KEY_PASSPHRASE=
# DRONE_SSH_PASSWORD=INSERTPASSWORDHERE
DRONE_START_SCRIPT_PATH=/home/pi/drone_workspace/drone-2026/start_drone.sh
DRONE_RECORDING_SCRIPT_PATH=/home/pi/drone_workspace/drone-2026/start_recording.sh
DRONE_MISSION_DIR=/home/pi/drone_workspace/drone-2026/ros_workspace/src/uav_mission/missions
DRONE_ROS_INSTALL=/home/pi/drone_workspace/drone-2026/ros_workspace/install/setup.bash
DRONE_TMUX_SESSION=drone_control
DRONE_TMUX_CAPTURE_LINES=2500
DRONE_TMUX_STOP_GRACE_SECONDS=60
DRONE_MISSION_EXTRA_ARGS=

# Local simulation overrides.
# SIM_COMPOSE_FILE=C:/Users/isaac/Desktop/drone-2026/SITL/web-sim/docker-compose.yml
SIM_COMPOSE_PROJECT=elytra-drone-2026
SIM_CONTAINER_NAME=drone-2026-sim
SIM_DRONE_START_SCRIPT_PATH=/home/sim/drone_workspace/drone-2026/start_drone.sh
SIM_DRONE_RECORDING_SCRIPT_PATH=/home/sim/drone_workspace/drone-2026/start_recording.sh
SIM_DRONE_MISSION_DIR=/home/sim/drone_workspace/drone-2026/ros_workspace/src/uav_mission/missions
SIM_DRONE_ROS_INSTALL=/home/sim/drone_workspace/drone-2026/ros_workspace/install/setup.bash
SIM_DRONE_TMUX_SESSION=drone_control
SIM_DRONE_TMUX_CAPTURE_LINES=2500
SIM_DRONE_TMUX_STOP_GRACE_SECONDS=20
SIM_DRONE_MISSION_EXTRA_ARGS=include_camera:=true camera_backend:=sim
SIM_NOVNC_ORIGIN=http://127.0.0.1:6080/vnc.html?autoconnect=1&resize=scale&path=websockify
SIM_AUTOSTOP_ON_DISCONNECT=0
RECONNECT_BACKOFF_MS=3000
